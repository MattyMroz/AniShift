# AniShift environment variables.
# Copy this file to `.env` and fill in the keys you need.
# All keys are optional — a missing key only disables that engine, not the app.
# System environment variables take precedence over `.env`.

# ── Translation ───────────────────────────────────────────────────────────────
ANISHIFT_DEEPL_API_KEY=

# ── TTS ───────────────────────────────────────────────────────────────────────
ANISHIFT_ELEVENLABS_API_KEY=

# ── LLM providers ─────────────────────────────────────────────────────────────
ANISHIFT_ANTHROPIC_API_KEY=
ANISHIFT_GEMINI_API_KEY=
ANISHIFT_OPENAI_API_KEY=
ANISHIFT_DEEPSEEK_API_KEY=
ANISHIFT_OPENROUTER_API_KEY=

# openai_compatible: point at any OpenAI-compatible server (self-hosted / gateway)
ANISHIFT_OPENAI_COMPATIBLE_API_KEY=
ANISHIFT_OPENAI_COMPATIBLE_BASE_URL=
